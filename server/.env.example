POSTGRES_PASSWORD=root
POSTGRES_DB=healthbridge

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRE=7d

# CORS
CORS_ORIGIN=http://localhost:5173
