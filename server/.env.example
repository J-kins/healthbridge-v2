# Server Configuration
PORT=5000
NODE_ENV=development

# Database - MySQL (if using MySQL)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=healthbridge

# Database - PostgreSQL (if using PostgreSQL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
